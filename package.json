{
  "name": "canvas-kit",
  "version": "0.2.4",
  "description": "A FigJam-style annotation toolbar for Obsidian Canvas.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "canvas",
    "annotation",
    "drawing",
    "figjam"
  ],
  "author": "yaye.work",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaye-work/canvas-kit.git"
  },
  "bugs": {
    "url": "https://github.com/yaye-work/canvas-kit/issues"
  },
  "homepage": "https://github.com/yaye-work/canvas-kit",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.21.0",
    "obsidian": "latest",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "perfect-freehand": "^1.2.2"
  }
}
